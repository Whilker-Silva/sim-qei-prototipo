# Opção 1: LLM local, sem chave externa. Baixa o modelo no primeiro docker compose up.
LLM_PROVIDER=ollama
OLLAMA_MODEL=qwen2.5:1.5b

# Opção 2: OpenAI API. Comente o ollama acima e use:
# LLM_PROVIDER=openai
# OPENAI_API_KEY=coloque_sua_chave_aqui
# OPENAI_MODEL=gpt-5.4-mini

LLM_TIMEOUT_SECONDS=45
